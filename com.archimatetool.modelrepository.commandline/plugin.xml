<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="com.archimatetool.commandline.commandlineProvider">
      <commandlineProvider
            class="com.archimatetool.modelrepository.commandline.CoreModelRepositoryProvider"
            description="Core options for collaboration repository"
            id="com.archimatetool.modelrepository.commandlineCoreModel"
            name="Core Options for Collaboration Model">
      </commandlineProvider>
      <commandlineProvider
            class="com.archimatetool.modelrepository.commandline.LoadModelProvider"
            description="Load from a local collaboration repository and set to the current model"
            id="com.archimatetool.modelrepository.commandlineCloneModel"
            name="Load Collaboration Model">
      </commandlineProvider>
      <commandlineProvider
            class="com.archimatetool.modelrepository.commandline.CloneModelProvider"
            description="Clone a collaboration repository to a local folder"
            id="com.archimatetool.modelrepository.commandlineCloneModel"
            name="Clone Collaboration Model">
      </commandlineProvider>
      <commandlineProvider
            class="com.archimatetool.modelrepository.commandline.PushModelToRepositoryProvider"
            description="Push a collaboration repository to a remote repository"
            id="com.archimatetool.modelrepository.commandlinePushModel"
            name="Push Collaboration Model">
      </commandlineProvider>
   </extension>

</plugin>
